{
  "name": "@nicolawealth/ioc",
  "type": "module",
  "version": "1.0.2",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.umd.js",
  "unpkg": "./dist/index.umd.js",
  "types": "./dist/types/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "require": "./dist/index.umd.js",
      "import": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist/"
  ],
  "author": "Nicola Wealth Inc",
  "contributors": [
    {
      "name": "Cliff Hammerschmidt"
    },
    {
      "name": "Skye Haik"
    },
    {
      "name": "Travis Rempel"
    },
    {
      "name": "Mel Delosada"
    }
  ],
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf dist/* && rm -f tsconfig.tsbuildinfo",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && npm run rename:esm",
    "build:other": "npm run build:cjs && npm run build:esm && tsc -b ./tsconfig.types.json",
    "build:gitactions": "npm run build:cjs && tsc -p tsconfig.esm.json && tsc -b ./tsconfig.types.json",
    "build": "microbundle --format umd",
    "rename:esm": "/bin/zsh ./scripts/fix-mjs.sh",
    "lint": "eslint src",
    "test": "mocha",
    "test-r": "mocha -R spec",
    "cover": "c8 mocha --config .mocharc.cjs",
    "cover:report": "c8 --reporter=html --reporter=lcov --reporter=text --reporter=json mocha --config .mocharc.cjs -c --reporter=spec",
    "cover:extract": "node scripts/extract-coverage.cjs",
    "doc": "npx typedoc src/*.ts src/**/*.ts --out dist/doc"
  },
  "c8": {
    "all": true,
    "check-coverage": true,
    "extension": [
      ".ts",
      ".tsx"
    ],
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ],
    "exclude": [
      "src/ioc.ts",
      "**/*_sql.ts",
      "**/*.test.ts",
      "**/src/@types/**/index.d.ts",
      "**/*.test_*.ts",
      "**/*.test.tsx",
      "**/*.test_*.tsx",
      "**/*.type.ts",
      "**/*.provider.ts",
      "**/*.default.ts",
      "**/*.default.tsx",
      "**/bootstrap.ts",
      "**/index.ts",
      "**/index.tsx"
    ],
    "statements": 100,
    "branches": 100,
    "lines": 100,
    "functions": 100
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@nicolawealth/defer_until": "^0.1.1"
  },
  "devDependencies": {
    "@nicolawealth/code_coverage_extractor": "^2",
    "@types/mocha": "^9",
    "@types/node": "^22",
    "@types/sinon": "^10",
    "@typescript-eslint/eslint-plugin": "^8",
    "c8": "^11.0.0",
    "eslint": "^9",
    "eslint-config-turbo": "^2",
    "microbundle": "^0.15.1",
    "mocha": "^10",
    "mocha-junit-reporter": "^2",
    "sinon": "^19",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.0"
}
